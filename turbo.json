{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "standalone/**", "node_modules/.cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env.*"]
    },
    "@talos/web#build": {
      "dependsOn": ["talos-web#build"],
      "outputs": ["dist/**", "standalone/**"]
    },
    "talos-web#build": {
      "outputs": [".next/**", "node_modules/.cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env.*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "eslint.config.mjs", ".eslintrc.*"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.ts"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["dist/**/*.d.ts", "dist/**/*.d.ts.map"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json"]
    },
    "clean": {
      "cache": false
    }
  }
}
